# Copie para native-local.env: cp native-local.env.example native-local.env
# URLs usam hostnames da rede Docker (postgres, minio).

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

QUARKUS_PROFILE=dev

DB_KIND=postgresql
DB_USERNAME=backoffice
DB_PASSWORD=backoffice
DB_URL=jdbc:postgresql://postgres:5432/backoffice

STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_BUCKET=backoffice
STORAGE_KEY_ENV_PREFIX=dev
STORAGE_UPLOAD_MAX_BYTES=5242880
STORAGE_UPLOAD_SIGN_TTL_SECONDS=300
STORAGE_UPLOAD_RATE_LIMIT_CAPACITY=30
STORAGE_UPLOAD_RATE_LIMIT_REFILL_MINUTES=1
